# Discord bot token
DISCORD_TOKEN=

# S3-compatible object storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ttrpg-dataset-raw
S3_ENDPOINT=https://nbg1.your-objectstorage.com

# Local buffer directory
LOCAL_BUFFER_DIR=./sessions

# Recording settings
MIN_PARTICIPANTS=2
REQUIRE_ALL_CONSENT=true

# Database
DATABASE_URL=postgres://user:password@localhost/ttrpg_collector
