# Discord bot token
DISCORD_TOKEN=

# Data API (the only storage interface — no direct S3 or Postgres)
DATA_API_URL=http://127.0.0.1:8001
DATA_API_SHARED_SECRET=

# Local buffer directory
LOCAL_BUFFER_DIR=./sessions

# Recording settings
MIN_PARTICIPANTS=1
REQUIRE_ALL_CONSENT=true

# Comma-separated Discord user IDs that auto-consent (dev/E2E harness only)
BYPASS_CONSENT_USER_IDS=

# Dev-only E2E harness HTTP server (POST /record, POST /stop, GET /health)
HARNESS_ENABLED=false
HARNESS_PORT=8010
