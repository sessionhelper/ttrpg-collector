# Discord bot token
DISCORD_TOKEN=

# Data API (the only storage interface — no direct S3 or Postgres)
DATA_API_URL=http://127.0.0.1:8001
DATA_API_SHARED_SECRET=

# Pre-consent chunk cache (empty = <tmpdir>/chronicle-bot, typically /tmp/chronicle-bot)
LOCAL_BUFFER_DIR=
LOCAL_BUFFER_MAX_SECS=7200

# Seconds of continuous healthy audio before the "Recording started" announcement plays
STABILIZATION_GATE_SECS=3

# Recording settings
MIN_PARTICIPANTS=1
REQUIRE_ALL_CONSENT=true

# Dev-only E2E harness HTTP server (POST /record, /enrol, /consent, /license, /stop, GET /health)
HARNESS_ENABLED=false
HARNESS_PORT=8010
